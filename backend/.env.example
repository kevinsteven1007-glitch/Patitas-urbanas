# Archivo de ejemplo para configuración de variables de entorno
# Asegúrate de reemplazar <user>, <password>, y <cluster-url> con tus credenciales reales de GCP Firestore.
# La URI DEBE incluir los parámetros obligatorios para Firestore/MongoDB.

MONGODB_URI="mongodb://<user>:<password>@<cluster-url>/?loadBalanced=true&tls=true&authMechanism=SCRAM-SHA-256&retryWrites=false"
PORT=3001

# Google Cloud Storage — Bucket para imágenes de mascotas
GCS_BUCKET_NAME="patitas-urbanas-imagenes"
GCS_PROJECT_ID="patitas-urbanas"
GCS_CREDENTIALS_PATH="./gcs-credentials.json"
